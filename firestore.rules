rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@echove.vn' || 
        request.auth.token.email == 'echove.official@gmail.com'
      );
    }

    // Users collection rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Products collection rules (if we transition products)
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders collection rules
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email);
    }

    // Donations collection rules
    match /donations/{donationId} {
      allow create: if true;
      allow read, update, delete: if isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email);
    }
  }
}
