rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@echove.vn' || 
        request.auth.token.email == 'echove.official@gmail.com' ||
        request.auth.token.email == 'anhnthe171401@fpt.edu.vn'
      );
    }

    // Users collection rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Products collection rules (if we transition products)
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders collection rules
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email);
    }

    // Donations collection rules
    match /donations/{donationId} {
      allow create: if true;
      allow read, update, delete: if isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email);
    }

    // Deleted Users collection rules
    match /deleted_users/{docId} {
      allow read, write: if isAdmin();
    }

    // Traffic logs collection rules
    match /traffic_logs/{logId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Vouchers collection rules
    match /vouchers/{voucherId} {
      allow read, update: if true;
      allow create, delete: if isAdmin();
    }

    // Emails collection rules
    match /emails/{emailId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Settings collection rules
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
